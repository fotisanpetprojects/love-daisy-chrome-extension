{
  "manifest_version": 3,
  "name": "Love Daisy",
  "description": "A tiny daisy-plucking fortune game for any page.",
  "version": "0.1.3",
  "action": {
    "default_title": "Pluck a daisy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
